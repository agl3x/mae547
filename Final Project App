                    delete(app.cms_kpkmd{i}); app.cms_kpkmd{i} = [];
                end
            end
            for i = 1:6
                if length(app.cms_he) >= i && ~isempty(app.cms_he{i}) && isvalid(app.cms_he{i})
                    delete(app.cms_he{i}); app.cms_he{i} = [];
                end
            end
        end
    end


