        function cmDeleteIndex1(app)
            single_types = {'cms_a', 'cms_alpha', 'cms_d', 'cms_theta', 'cms_rp', 'cms_icDot', 'cms_icDoubleDot', 'cms_dEquation', 'cms_mJoint', 'cms_IJoint', 'cms_kr', 'cms_sf', 'cms_vf', 'cms_mLink', 'cms_ILink', 'cms_ifcEquation'};
            for i = 1:length(single_types)
                field = single_types{i};
                if ~isempty(app.(field)) && length(app.(field)) >= 1 && ~isempty(app.(field){1}) && isvalid(app.(field){1})
                    delete(app.(field){1});
                    app.(field){1} = [];
                end
            end
            for i = 1:3
                if length(app.cms_g) >= i && ~isempty(app.cms_g{i}) && isvalid(app.cms_g{i})
