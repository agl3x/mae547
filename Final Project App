    methods (Access = private)
        function updateContextMenu(app, i, type)
            switch type
                case 'a'
                    app.aMenu(i).Text = sprintf('Joint %d a-Value: %s m', i, num2str(app.aValue(i).Value));
                case 'alpha'
                    app.alphaMenu(i).Text = sprintf('Joint %d alpha-Value: %s rad', i, num2str(app.alphaValue(i).Value));
                case 'd'
                    if strcmp(app.rpValues{i}, 'Revolut')
                        app.dMenu(i).Text = sprintf('Joint %d d-Value: %s m', i, num2str(app.dValue(i).Value));
                    else
                        app.dMenu(i).Text = sprintf('Joint %d d-Value: d%s + %s m', i, char(8320 + i), num2str(app.dValue(i).Value));
                    end
                case 'theta'
                    if strcmp(app.rpValues{i}, 'Revolut')
                        app.thetaMenu(i).Text = sprintf('Joint %d theta-Value: θ%s + %s rad', i, char(8320 + i), num2str(app.thetaValue(i).Value));
                    else
                        app.thetaMenu(i).Text = sprintf('Joint %d theta-Value: %s rad', i, num2str(app.thetaValue(i).Value));
                    end
                case 'rp'
                    if i <= length(app.rpValues) && ~isempty(app.rpValues{i})
                        app.rpMenu(i).Text = sprintf('Joint %d is: %s', i, app.rpValues{i});
                    else
                        app.rpMenu(i).Text = sprintf('Joint %d is: Revolut', i);
                    end
                case 'icDot'
                    if strcmp(app.rpValues{i}, 'Revolut')
                        app.icDotMenu(i).Text = sprintf('Joint %d Initial Angular Velocity: %s m/s', i, num2str(app.icDotValue(i).Value));
                    else
                        app.icDotMenu(i).Text = sprintf('Joint %d Initial Velocity: %s m/s', i, num2str(app.icDotValue(i).Value));
                    end
                case 'icDoubleDot'
                    if strcmp(app.rpValues{i}, 'Revolut')
                        app.icDoubleDotMenu(i).Text = sprintf('Joint %d Initial Angular Acceleration: %s m/s²', i, num2str(app.icDoubleDotValue(i).Value));
                    else
                        app.icDoubleDotMenu(i).Text = sprintf('Joint %d Initial Acceleration: %s m/s²', i, num2str(app.icDoubleDotValue(i).Value));
                    end
                case 'dEquation'
                    app.dEquationMenu(i).Text = sprintf('Joint %d τ = %s', i, num2str(app.dEquation(i).Value));
                case 'mJoint'
                    app.mJointMenu(i).Text = sprintf('Joint %d Mass: %s kg', i, num2str(app.mJointValue(i).Value));
                case 'IJoint'
                    app.IJointMenu(i).Text = sprintf('Joint %d Moment of Inertia: %s kg·m²', i, num2str(app.IJointValue(i).Value));
                case 'kr'
                    app.krMenu(i).Text = sprintf('Joint %d Gear Ratio: %s', i, num2str(app.krValue(i).Value));
                case 'sf'
                    app.sfMenu(i).Text = sprintf('Joint %d Static Friction: %s', i, num2str(app.sfValue(i).Value));
                case 'vf'
                    app.vfMenu(i).Text = sprintf('Joint %d Viscous Friction: %s', i, num2str(app.vfValue(i).Value));
                case 'mLink'
                    app.mLinkMenu(i).Text = sprintf('Link %d Mass: %s kg', i, num2str(app.mLinkValue(i).Value));
                case 'ILink'
                    app.ILinkMenu(i).Text = sprintf('Link %d Moment of Inertia: %s kg·m²', i, num2str(app.ILinkValue(i).Value));
                case 'gx'
                    app.gxMenu(i).Text = sprintf('Gravity in the x: %s m/s²', num2str(app.gxValue(i).Value));
                case 'gy'
                    app.gyMenu(i).Text = sprintf('Gravity in the y: %s m/s²', num2str(app.gyValue(i).Value));
                case 'gz'
                    app.gzMenu(i).Text = sprintf('Gravity in the z: %s m/s²', num2str(app.gzValue(i).Value));
                case 'hefx'
                    app.hefxMenu(i).Text = sprintf('Force in the x: %s N', num2str(app.hefxValue(i).Value));
                case 'hefy'
                    app.hefyMenu(i).Text = sprintf('Force in the y: %s N', num2str(app.hefyValue(i).Value));
                case 'hefz'
                    app.hefzMenu(i).Text = sprintf('Force in the z: %s N', num2str(app.hefzValue(i).Value));
                case 'hemx'
                    app.hemxMenu(i).Text = sprintf('Moment about x: %s N·m', num2str(app.hemxValue(i).Value));
                case 'hemy'
                    app.hemyMenu(i).Text = sprintf('Moment about y: %s N·m', num2str(app.hemyValue(i).Value));
                case 'hemz'
                    app.hemzMenu(i).Text = sprintf('Moment about z: %s N·m', num2str(app.hemzValue(i).Value));
                case 'kp'
                    app.kpMenu(i).Text = sprintf('kp-Value: %s', num2str(app.kpValue(i).Value));
                case 'k'
                    if app.MainMenus.SelectedObject == app.IFCCButton
                        app.kMenu(i).Text = sprintf('k-Value: %s', num2str(app.kValue(i).Value));
                    else
                        app.kMenu(i).Text = sprintf('kd-Value: %s', num2str(app.kValue(i).Value));
                    end
                case 'md'
                    app.mdMenu(i).Text = sprintf('md-Value: %s', num2str(app.mdValue(i).Value));
                case 'ifcEquation'
                    app.ifcEquationMenu(i).Text = sprintf('x_d = %s', num2str(app.ifcEquation(i).Value));
            end
        end

